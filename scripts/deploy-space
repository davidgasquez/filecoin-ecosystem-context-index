#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SPACE_ID="${HF_SPACE_ID:-davidgasquez/filecoin-docs-qmd-mcp}"
DATASET_ID="${HF_DATASET_ID:-davidgasquez/filecoin-docs-qmd}"
DATASET_REVISION="${HF_DATASET_REVISION:-main}"

if [ -f "$REPO_ROOT/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  . "$REPO_ROOT/.env"
  set +a
  SPACE_ID="${HF_SPACE_ID:-$SPACE_ID}"
  DATASET_ID="${HF_DATASET_ID:-$DATASET_ID}"
  DATASET_REVISION="${HF_DATASET_REVISION:-$DATASET_REVISION}"
fi

if ! command -v uvx >/dev/null 2>&1; then
  echo "error: uvx is required" >&2
  exit 1
fi

STAGE="$(mktemp -d)"
trap 'rm -rf "$STAGE"' EXIT

mkdir -p "$STAGE/scripts" "$STAGE/qmd"
cp "$REPO_ROOT/Dockerfile" "$REPO_ROOT/.dockerignore" "$STAGE/"
sed -i "s|^ARG FILECOIN_DOCS_QMD_DATASET=.*|ARG FILECOIN_DOCS_QMD_DATASET=$DATASET_ID|" "$STAGE/Dockerfile"
sed -i "s|^ARG FILECOIN_DOCS_QMD_REVISION=.*|ARG FILECOIN_DOCS_QMD_REVISION=$DATASET_REVISION|" "$STAGE/Dockerfile"
cp "$REPO_ROOT/scripts/serve-mcp.mjs" "$STAGE/scripts/"
cp "$REPO_ROOT/qmd/index.yml" "$STAGE/qmd/"
cat > "$STAGE/README.md" <<EOF
---
title: Filecoin Docs QMD MCP
emoji: 🔎
colorFrom: blue
colorTo: indigo
sdk: docker
app_port: 7860
datasets:
  - $DATASET_ID
---

# Filecoin Docs QMD MCP

MCP server backed by a prebuilt QMD index of Filecoin docs and code.

Endpoint: \`/mcp\`
Health: \`/health\`
EOF

uvx --from huggingface_hub hf repos create "$SPACE_ID" \
  --type space \
  --space-sdk docker \
  --flavor cpu-basic \
  --exist-ok

uvx --from huggingface_hub hf upload "$SPACE_ID" "$STAGE" . \
  --repo-type space \
  --commit-message "Deploy QMD MCP server"

echo "Space: https://huggingface.co/spaces/$SPACE_ID"
echo "MCP:   https://${SPACE_ID//\//-}.hf.space/mcp"
echo "Health: https://${SPACE_ID//\//-}.hf.space/health"
